# ============================================
# AIRA — Autonomous Intelligent Reasoning Agent
# Environment Configuration
# ============================================
# Copy this file to .env and update values
# cp .env.example .env

# ---------- Flask ----------
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-in-production
JWT_SECRET_KEY=change-this-to-a-random-jwt-secret-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ---------- MongoDB ----------
MONGODB_URI=mongodb://mongodb:27017/aira
MONGODB_DB_NAME=aira

# ---------- Ollama ----------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3-coder
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_REQUEST_TIMEOUT=120

# ---------- ChromaDB ----------
CHROMADB_PATH=./data/embeddings

# ---------- Upload ----------
MAX_UPLOAD_SIZE_MB=100
UPLOAD_FOLDER=./data/uploads

# ---------- Workspace ----------
WORKSPACE_FOLDER=./data/workspace

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FILE=./logs/aira.log

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------- Rate Limiting ----------
RATELIMIT_STORAGE_URL=memory://
RATELIMIT_DEFAULT=100/hour

# ---------- Frontend (Build-time) ----------
VITE_API_URL=http://localhost:5000
